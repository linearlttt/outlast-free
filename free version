local function ATWVD_fake_script() -- Frame.LocalScript 
	local script = Instance.new('LocalScript', Frame)

	local dragger = {}
	local resizer = {}
	
	local Players = game:GetService("Players")
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local mouse = player:GetMouse()
	
	-- =========================
	-- DRAGGER
	-- =========================
	function dragger.new(frame)
		local dragging = false
		local dragInput
		local startPos
		local startFramePos
	
		frame.Active = true
	
		frame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				startPos = input.Position
				startFramePos = frame.Position
	
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)
	
		frame.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				dragInput = input
			end
		end)
	
		RunService.Heartbeat:Connect(function()
			if dragging and dragInput then
				local delta = dragInput.Position - startPos
	
				frame.Position = UDim2.new(
					startFramePos.X.Scale,
					startFramePos.X.Offset + delta.X,
					startFramePos.Y.Scale,
					startFramePos.Y.Offset + delta.Y
				)
			end
		end)
	end
	
	-- =========================
	-- RESIZER
	-- =========================
	function resizer.new(parent, frame)
		parent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
			frame.Size = UDim2.new(
				frame.Size.X.Scale,
				frame.Size.X.Offset,
				frame.Size.Y.Scale,
				parent.AbsoluteSize.Y
			)
		end)
	end
	
	-- =========================
	-- APPLY
	-- =========================
	local frame = script.Parent
	
	dragger.new(frame)
	frame.Active = true
	frame.Draggable = true -- disable old roblox drag (we use custom)
end
coroutine.wrap(ATWVD_fake_script)()
local function HHXDRY_fake_script() -- TextLabel.LocalScript 
	local script = Instance.new('LocalScript', TextLabel)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local LocalPlayer = Players.LocalPlayer
	local button = script.Parent:FindFirstChild("WipButton")
	
	local Toggle = false
	local antifling = false
	local LastPosition = nil
	local debounce = false
	
	local Tracked = {}
	
	local function TrackPlayer(player)
		if player == LocalPlayer then return end
	
		local data = {
			Character = nil,
			Primary = nil
		}
		Tracked[player] = data
	
		local function CharacterAdded(char)
			data.Character = char
			data.Primary = char:WaitForChild("HumanoidRootPart", 5)
		end
	
		if player.Character then
			CharacterAdded(player.Character)
		end
		player.CharacterAdded:Connect(CharacterAdded)
	end
	
	--// EXISTING + NEW PLAYERS
	for _, p in ipairs(Players:GetPlayers()) do
		TrackPlayer(p)
	end
	Players.PlayerAdded:Connect(TrackPlayer)
	Players.PlayerRemoving:Connect(function(p)
		Tracked[p] = nil
	end)
	
	RunService.RenderStepped:Connect(function()
		if not Toggle then return end
	
		for _, data in pairs(Tracked) do
			local char = data.Character
			local root = data.Primary
	
			if char and root and char:IsDescendantOf(workspace) then
				if root.AssemblyAngularVelocity.Magnitude > 50
					or root.AssemblyLinearVelocity.Magnitude > 100 then
					for _, part in ipairs(char:GetDescendants()) do
						if part:IsA("BasePart") then
							part.CanCollide = false
							part.AssemblyAngularVelocity = Vector3.zero
							part.AssemblyLinearVelocity = Vector3.zero
							part.CustomPhysicalProperties = PhysicalProperties.new(0,0,0)
						end
					end
				end
			end
		end
	
		local char = LocalPlayer.Character
		if not char or not char.PrimaryPart then return end
		local primary = char.PrimaryPart
	
		local lv = primary.AssemblyLinearVelocity.Magnitude
		local av = primary.AssemblyAngularVelocity.Magnitude
	
		if lv > 250 or av > 250 then
			primary.AssemblyLinearVelocity = Vector3.zero
			primary.AssemblyAngularVelocity = Vector3.zero
			if LastPosition then
				primary.CFrame = LastPosition
			end
		elseif lv < 50 and av < 50 then
			LastPosition = primary.CFrame
		end
	end)
	
	button.MouseButton1Click:Connect(function()
		if debounce then return end
		debounce = true
	
		Toggle = not Toggle
		antifling = Toggle
	
		button.BackgroundColor3 = Toggle
			and Color3.fromRGB(51, 255, 47)
			or Color3.fromRGB(255, 0, 0)
	
		task.delay(0.15, function()
			debounce = false
		end)
	end)
end
