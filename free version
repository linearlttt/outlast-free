local function IEPKDZQ_fake_script() -- bSliderFrame.mainScript 
	local script = Instance.new('LocalScript', bSliderFrame)

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	
	-- =========================
	-- Slider Setup
	-- =========================
	local slider = script.Parent
	local slideFrame = slider:WaitForChild("slideFrame")
	local amountValue = slider:WaitForChild("amountValue")
	
	local MIN_VALUE = 0
	local MAX_VALUE = 1
	local currentValue = MIN_VALUE
	local dragging = false
	local wipEnabled = false -- will be toggled by button
	
	local function updateSlider(pos)
		if not wipEnabled then return end
	
		-- Update slider UI
		slideFrame:TweenSize(
			UDim2.new(pos, 0, 1, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.1,
			true
		)
	
		-- Update current value
		currentValue = MIN_VALUE + (pos * (MAX_VALUE - MIN_VALUE))
		currentValue = math.floor(currentValue * 100) / 100 -- round to 2 decimals
		amountValue.Text = tostring(currentValue)
	
		-- Update global interval
		_G.WeaveInterval = currentValue
	end
	
	local function getInputPosition(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement 
			or input.UserInputType == Enum.UserInputType.MouseButton1 
			or input.UserInputType == Enum.UserInputType.Touch then
			return input.Position.X
		end
	end
	
	-- =========================
	-- Slider Input Handling
	-- =========================
	slider.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	slider.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local pos = math.clamp((getInputPosition(input) - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
			updateSlider(pos)
		end
	end)
	
	-- =========================
	-- Wip Button Setup
	-- =========================
	_G.WeaveEnabled = false
	_G.WeaveInterval = currentValue
	local parentRoot = slider.Parent.Parent
	local wipButton = parentRoot:FindFirstChild("WipButton")
	
	if wipButton then
		wipButton.MouseButton1Click:Connect(function()
			wipEnabled = not wipEnabled
			if wipEnabled then
				_G.WeaveEnabled = true
				wipButton.BackgroundColor3 = Color3.fromRGB(51, 255, 47)
			else
				_G.WeaveEnabled = false
				wipButton.BackgroundColor3 = Color3.fromRGB(255, 11, 0)
			end
		end)
	end
	
	-- =========================
	-- Remote Function
	-- =========================
	local function getRemote()
		local char = LocalPlayer.Character
		if not char then return end
	
		local core = char:FindFirstChild("Core")
		if not core then return end
	
		local comm = core:FindFirstChild("Communicate")
		if not comm then return end
	
		for _, v in pairs(comm:GetChildren()) do
			if v:IsA("RemoteEvent") then
				return v
			end
		end
	end
	
	-- =========================
	-- Animation Trigger Logic
	-- =========================
	local MAX_DISTANCE = 5 -- studs
	local lastFireTimes = {} -- to track reaction cooldowns per player
	
	local function getHumanoidRootPart(player)
		local char = player.Character
		if char then
			return char:FindFirstChild("HumanoidRootPart")
		end
	end
	
	local function isClose(player)
		local localHRP = getHumanoidRootPart(LocalPlayer)
		local otherHRP = getHumanoidRootPart(player)
		if not localHRP or not otherHRP then return false end
		return (localHRP.Position - otherHRP.Position).Magnitude <= MAX_DISTANCE
	end
	
	local function onAnimationPlayed(player, track)
		if not _G.WeaveEnabled then return end
		if not isClose(player) then return end
	
		local now = os.clock()
		local lastFire = lastFireTimes[player] or 0
		local interval = math.max(0.01, _G.WeaveInterval) -- prevent zero interval
	
		if now - lastFire >= interval then
			lastFireTimes[player] = now
			local remote = getRemote()
			if remote then
				pcall(function()
					remote:FireServer("Weave", nil, true)
				end)
			end
		end
	end
	
	local function monitorPlayer(player)
		player.CharacterAdded:Connect(function(char)
			task.wait(0.1)
			local humanoid = char:FindFirstChildWhichIsA("Humanoid")
			if not humanoid then return end
			local animator = humanoid:FindFirstChildOfClass("Animator")
			if not animator then return end
	
			animator.AnimationPlayed:Connect(function(track)
				onAnimationPlayed(player, track)
			end)
		end)
	
		if player.Character then
			local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
			if humanoid then
				local animator = humanoid:FindFirstChildOfClass("Animator")
				if animator then
					animator.AnimationPlayed:Connect(function(track)
						onAnimationPlayed(player, track)
					end)
				end
			end
		end
	end
	
	-- Monitor existing players
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			monitorPlayer(player)
		end
	end
	
	-- Monitor new players
	Players.PlayerAdded:Connect(function(player)
		if player ~= LocalPlayer then
			monitorPlayer(player)
		end
